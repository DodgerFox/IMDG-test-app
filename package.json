{
  "name": "imdg-app",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest --config=vitest.config.ts",
    "lint": "eslint './src/**/*.{ts,js,svelte}' --max-warnings=0 || true",
    "format": "prettier --write './src/**/*.{ts,js,svelte,json,md}'"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.5.18",
    "@types/node": "^22.15.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "svelte": "^5.46.4",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^8.0.0",
    "vitest": "^1.0.0",
    "zod": "^4.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "prettier": "^2.0.0",
    
    "svelte-eslint-parser": "^1.0.0",
    "eslint-config-prettier": "^9.0.0"
  }
}